# Виртуальное окружение
.venv/
venv/
env/
ENV/

# Кэш Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Файлы сборки
dist/
build/
*.spec
installer/

# Логи и бэкапы (создаются при работе программы)
logs/
backups/
*.log

# База данных (не включаем в репозиторий)
subscribers.db

# Файлы IDE
.vscode/
.idea/
*.swp
*.swo

# Временные файлы
*.tmp
*.bak
*.orig